%%metro title: nf-denovoslim
%%metro style: light
%%metro line: main | Assembly | #2db572
%%metro line: quant | Quantification | #457b9d
%%metro line: annot | Annotation | #f5c542

graph LR
    subgraph preprocess [Pre-processing]
        _input
        sortmerna[SortMeRNA]
        _input -->|main,quant| sortmerna
    end

    subgraph clustering [Transcript Clustering]
        salmon_init[Salmon Quant]
        corset[Corset]
        select_rep[Select Rep]
        salmon_init -->|main,quant| corset
        corset -->|main| select_rep
    end

    subgraph filtering [Filtering & Reduction]
        taxonomy[Taxonomy Filter]
        nt_cluster[NT Cluster 90%]
        locus_cluster[Locus Cluster]
        taxonomy -->|main| nt_cluster
        nt_cluster -->|main| locus_cluster
    end

    subgraph correction [Frameshift Correction]
        diamond[Diamond BLASTX]
        frameshifts[Correct Frameshifts]
        diamond -->|main| frameshifts
    end

    subgraph orf_pred [ORF Prediction]
        td2[TD2 LongOrfs]
        homology[Homology Search]
        td2_predict[TD2 Predict]
        best_orf[Select Best ORF]
        metaeuk[MetaEuk]
        gmst[GeneMarkS-T]
        td2 -->|main,annot| homology
        homology -->|annot| td2_predict
        td2_predict -->|main| best_orf
    end

    subgraph merge_section [Merge & Refinement]
        merge[Merge Predictions]
        hmmer[HMMER Extend]
        prot_cluster[Protein Cluster 95%]
        merge -->|main| hmmer
        hmmer -->|main| prot_cluster
    end

    subgraph quantification [Quantification]
        salmon_gene[Gene-level Quant]
        validate[Validate IDs]
        decontam[Decontaminate]
        salmon_full[Full Trinity Quant]
        tx2gene[Build tx2gene]
        salmon_gene -->|quant| validate
        decontam -->|quant| salmon_full
        salmon_full -->|quant| tx2gene
    end

    subgraph output [QC & Output]
        busco_qc[BUSCO Proteins]
        transannot[TransAnnot]
        report[Thinning Report]
        busco_qc -->|main| report
        transannot -->|annot| report
    end

    %% Assembly route
    sortmerna -->|main| salmon_init
    select_rep -->|main| taxonomy
    locus_cluster -->|main| diamond
    frameshifts -->|main| td2
    frameshifts -->|main| metaeuk
    frameshifts -->|main| gmst
    best_orf -->|main| merge
    metaeuk -->|main| merge
    gmst -->|main| merge
    prot_cluster -->|main| busco_qc

    %% Quantification route
    sortmerna -->|quant| salmon_init
    frameshifts -->|quant| salmon_gene
    corset -->|quant| decontam
    prot_cluster -->|quant| tx2gene
    validate -->|quant| report
    tx2gene -->|quant| report

    %% Annotation route
    prot_cluster -->|annot| transannot
